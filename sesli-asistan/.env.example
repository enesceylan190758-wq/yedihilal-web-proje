# YediHilal Sesli Asistan - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

# Retell AI API anahtarı (https://dashboard.retellai.com)
RETELL_API_KEY=

# Retell agent ID (Dashboard > Agents)
RETELL_AGENT_ID=

# Google Gemini API anahtarı (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Ngrok veya production WebSocket URL'si
# Örnek: wss://xxxx.ngrok-free.app/llm-websocket
LLM_WEBSOCKET_URL=
